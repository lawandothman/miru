{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@miru/typescript-config/nextjs.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
