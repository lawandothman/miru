{
	"cli": {
		"version": ">= 16.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"base": {
			"node": "24.15.0"
		},
		"development": {
			"extends": "base",
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development",
			"ios": {
				"simulator": true
			}
		},
		"preview": {
			"extends": "base",
			"distribution": "internal",
			"channel": "preview"
		},
		"production": {
			"extends": "base",
			"autoIncrement": true,
			"channel": "production"
		}
	},
	"submit": {
		"production": {
			"ios": {
				"ascAppId": "6759829491",
				"appleTeamId": "LY9UXT2PY8"
			}
		}
	}
}
