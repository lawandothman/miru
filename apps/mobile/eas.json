{
	"cli": {
		"version": ">= 16.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development",
			"ios": {
				"simulator": true
			}
		},
		"preview": {
			"distribution": "internal",
			"channel": "preview",
			"env": {
				"EXPO_PUBLIC_API_URL": "https://miru-chi.vercel.app"
			}
		},
		"production": {
			"autoIncrement": true,
			"channel": "production",
			"env": {
				"EXPO_PUBLIC_API_URL": "https://miru-chi.vercel.app"
			}
		}
	},
	"submit": {
		"production": {
			"ios": {
				"ascAppId": "6759829491",
				"appleTeamId": "LY9UXT2PY8"
			}
		}
	}
}
