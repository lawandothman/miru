{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./base.json",
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2024"],
		"jsx": "preserve",
		"noEmit": true,
		"incremental": true,
		"declaration": false,
		"declarationMap": false,
		"verbatimModuleSyntax": false,
		"plugins": [{ "name": "next" }]
	}
}
